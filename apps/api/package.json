  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^11.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2"
  }
