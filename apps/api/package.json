{
  "name": "api",
  "version": "1.0.0",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node --transpile-only src/scripts/seed.ts",
    "reindex": "ts-node --transpile-only src/scripts/reindex.ts",
    "migrate": "echo 'Migrations are run via sequelize-cli, use `npx sequelize-cli db:migrate` or custom script'"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^7.1.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.9.7",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "sequelize": "^6.37.3",
    "socket.io": "^4.7.5",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
